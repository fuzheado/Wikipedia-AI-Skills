# Wikimedia Database Connection
# Copy this to .env and fill in your credentials.
# Get your replica credentials from https://admin.toolforge.org/ (MySQL Databases section)

# Your Toolforge shell/LDAP username
TOOLFORGE_USER="your-toolforge-username"

# Replica database username (starts with "u", e.g., u12345)
TOOLFORGE_SQL_USER="u12345"

# Replica database password
TOOLFORGE_SQL_PASSWORD="your-password-here"

# Local port for SSH tunnel (optional, default 3307)
# Change if you have a local MySQL/MariaDB running on 3307
# TOOLFORGE_DB_PORT="3307"
